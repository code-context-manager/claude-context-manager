{
  "name": "claude-context-manager",
  "version": "0.1.0",
  "description": "Context-driven development for Claude Code — a desktop app that visualizes and curates the context Claude Code loads.",
  "main": "out/main/index.js",
  "homepage": "https://github.com/code-context-manager/claude-context-manager",
  "repository": {
    "type": "git",
    "url": "https://github.com/code-context-manager/claude-context-manager.git"
  },
  "bugs": {
    "url": "https://github.com/code-context-manager/claude-context-manager/issues"
  },
  "author": {
    "name": "Ruskin Janowski",
    "email": "ruskin.janowski@gmail.com"
  },
  "license": "ISC",
  "bin": {
    "claude-context-mcp": "out/mcp/index.mjs"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "mcp:dev": "tsx src/mcp/index.ts",
    "mcp:build": "esbuild src/mcp/index.ts --bundle --platform=node --format=esm --packages=external --outfile=out/mcp/index.mjs && node -e \"require('fs').chmodSync('out/mcp/index.mjs', 0o755)\"",
    "postinstall": "pnpm mcp:build",
    "dist:mac": "electron-builder --mac --arm64 --x64 --publish always",
    "dist:win": "electron-builder --win --publish always",
    "dist:linux": "electron-builder --linux --publish always"
  },
  "keywords": [],
  "packageManager": "pnpm@10.18.3",
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "esbuild": "^0.28.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "zustand": "^5.0.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "electron-updater": "^6.3.9",
    "lucide-react": "^1.14.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "build": {
    "appId": "com.claudecontextmanager.app",
    "productName": "Claude Context Manager",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "out/mcp/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "artifactName": "claude-context-manager-${version}-${arch}.${ext}",
      "icon": "build/icon.png"
    },
    "dmg": {
      "sign": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "claude-context-manager-${version}-${arch}.${ext}",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "claude-context-manager-${version}-${arch}.${ext}",
      "icon": "build/icon.png",
      "category": "Development"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "code-context-manager",
        "repo": "claude-context-manager"
      }
    ]
  }
}
